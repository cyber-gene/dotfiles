font-family = UDEV Gothic 35NFLG
font-size = 14
font-thicken = true

adjust-cell-height = 20%

theme = Monokai Pro

window-height = 45
window-width = 180
window-padding-x = 8
window-padding-y = 4,8
window-padding-balance = true

link-url = true

quit-after-last-window-closed

auto-update = download
auto-update-channel = stable

